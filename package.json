{
  "name": "affinity-script-manager",
  "version": "1.3.1",
  "description": "Graphic UI for uploading and dowloading Affinity App Scripts",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.example.affinityscriptmanager",
    "productName": "Affinity Script Manager",
    "files": [
      "**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  }
}
